{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Refract",
  "version": "1.1.3",
  "identifier": "com.refract",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "pnpm dev:real",
    "beforeBuildCommand": "pnpm build:real"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Refract",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
